{
  "name": "bitforge/thorm",
  "description": "PHP-first UI framework that compiles a declarative DSL to a small browser runtime via a shared IR.",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "Thorm\\": "src/php/",
      "Hronic\\": "examples/tests/hronic/"
    },
    "files": [
      "src/php/functions.php",
      "src/php/tags.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0"
  }
}
